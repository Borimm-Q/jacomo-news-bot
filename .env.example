# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 실제 값을 채워 넣으세요. (로컬 테스트용)
# 실제 운영(클라우드)에서는 GitHub Secrets 에 같은 이름으로 등록합니다.
# .env 는 절대 깃에 올리지 않습니다 (.gitignore 에 등록됨).

# 텔레그램 봇 토큰 (@BotFather 에서 발급)
TELEGRAM_BOT_TOKEN=

# 속보를 올릴 채널/그룹 ID. 공개 채널이면 @채널이름, 비공개·그룹이면 -100으로 시작하는 숫자 ID
TELEGRAM_CHANNEL_ID=

# (선택) 포럼(주제별) 그룹의 특정 토픽에만 쏠 때 그 토픽 ID. 일반 채널이면 비워둠.
# 예: 자코모 본방의 "뉴스, 속보" 토픽 = 234566
TELEGRAM_THREAD_ID=

# 구글 제미나이(Gemini) 무료 API 키 (https://aistudio.google.com/apikey) — 가공 엔진, 비용 $0
GEMINI_API_KEY=

# (선택) 제미나이 모델명. 비우면 gemini-2.0-flash
GEMINI_MODEL=

# Finnhub 무료 API 키 (https://finnhub.io/) — 시장·매크로·지정학·환율·M&A 뉴스용 (핵심)
FINNHUB_TOKEN=

# CryptoPanic 무료 API 토큰 (https://cryptopanic.com/developers/api/) — 코인 뉴스 보강용(선택)
CRYPTOPANIC_TOKEN=

# (선택) 한 번 실행할 때 발행할 최대 건수. 비우면 기본 8
MAX_POSTS_PER_RUN=8

# (선택) DRY_RUN=1 이면 텔레그램에 실제로 보내지 않고 콘솔에만 출력 (테스트용)
DRY_RUN=0
